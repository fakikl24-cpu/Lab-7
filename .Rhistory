?geom_point
?geom_smooth
?labels
?labs
ggplot(df_colonists, aes(x = age, y = marsgar)) +
geom_point(colour = "orange", size = 4) +
geom_smooth() +
labs(
title = "Colonist Age and Health",
x = "Age",
y = "MARSGAR"
)
ggplot(df_colonists, aes(x = age, y = marsgar)) +
